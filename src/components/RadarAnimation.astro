---
---

<div class="relative w-full max-w-md mx-auto aspect-square" aria-hidden="true">
  <!-- Outer ring -->
  <div class="absolute inset-0 rounded-full border border-signal-cyan/20 animate-pulse-glow"></div>
  <div class="absolute inset-4 rounded-full border border-signal-cyan/10"></div>
  <div class="absolute inset-8 rounded-full border border-signal-cyan/5"></div>

  <!-- Cross hairs -->
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="w-full h-px bg-signal-cyan/20"></div>
  </div>
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="w-px h-full bg-signal-cyan/20"></div>
  </div>

  <!-- Rotating sweep -->
  <div class="absolute inset-0 animate-radar-spin">
    <div class="absolute top-1/2 left-1/2 w-1/2 h-px origin-left
                bg-gradient-to-r from-signal-cyan/80 to-transparent"
         style="transform: translateY(-50%);">
    </div>
    <div class="absolute top-1/2 left-1/2 w-1/2 h-24 origin-left -translate-y-full
                bg-gradient-to-r from-signal-cyan/10 to-transparent rounded-full"
         style="clip-path: polygon(0 100%, 100% 0, 100% 100%);">
    </div>
  </div>

  <!-- Center dot -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
              w-3 h-3 rounded-full bg-signal-cyan shadow-[0_0_20px_rgba(64,255,208,0.8)]">
  </div>

  <!-- Blips (underground targets) -->
  <div class="absolute top-[35%] left-[60%] w-2 h-2 rounded-full bg-accent-orange/80
              shadow-[0_0_12px_rgba(255,170,0,0.6)] animate-pulse"></div>
  <div class="absolute top-[55%] left-[30%] w-1.5 h-1.5 rounded-full bg-signal-cyan/60
              shadow-[0_0_8px_rgba(64,255,208,0.5)] animate-pulse"
       style="animation-delay: 1s;"></div>
  <div class="absolute top-[70%] left-[55%] w-2.5 h-2.5 rounded-full bg-accent-orange/50
              shadow-[0_0_15px_rgba(255,170,0,0.4)] animate-pulse"
       style="animation-delay: 2s;"></div>

  <!-- Scan sweep line -->
  <div class="absolute inset-0 overflow-hidden rounded-full">
    <div class="absolute inset-x-0 h-16 bg-gradient-to-b from-transparent via-signal-cyan/10 to-transparent
                animate-scan-sweep"></div>
  </div>
</div>
