---
import type { Translations } from '../i18n/types';
import { YOUTUBE_CHANNEL_URL } from '../i18n/types';
import { getChannelVideos } from '../lib/youtube';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const videos = await getChannelVideos();
const [featured, ...rest] = videos;

function formatDate(iso: string): string {
  const locales = [t.locale, t.lang, 'en-US'];
  for (const locale of locales) {
    try {
      return new Intl.DateTimeFormat(locale, {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).format(new Date(iso));
    } catch {
      continue;
    }
  }
  return iso.slice(0, 10);
}

const videoSchema = videos.map(video => ({
  '@type': 'VideoObject',
  name: video.displayTitle,
  description: `${video.displayTitle} — ${t.videos.schemaSuffix}`,
  thumbnailUrl: video.thumbnail,
  uploadDate: video.published,
  contentUrl: video.watchUrl,
  embedUrl: video.embedUrl,
  publisher: {
    '@type': 'Organization',
    name: 'SubScan',
    url: YOUTUBE_CHANNEL_URL,
  },
}));
---

{videos.length > 0 && (
  <section id="videolar" class="py-16 sm:py-24 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10 sm:mb-12">
        <span class="text-xs font-mono text-signal-cyan tracking-widest">{t.videos.section}</span>
        <h2 class="section-title mt-2">{t.videos.title}</h2>
        <p class="text-white/50 mt-4 max-w-2xl mx-auto text-sm sm:text-base">{t.videos.subtitle}</p>
      </div>

      {featured && (
        <div class="glass-panel border border-white/10 overflow-hidden mb-6 sm:mb-8">
          <div class="aspect-video w-full bg-black/60">
            <iframe
              src={`${featured.embedUrl}?rel=0`}
              title={featured.displayTitle}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              class="w-full h-full border-0"
            />
          </div>
          <div class="p-4 sm:p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div class="min-w-0">
              <h3 class="font-semibold text-white/90 truncate">{featured.displayTitle}</h3>
              <p class="text-xs text-white/40 mt-1">{formatDate(featured.published)}</p>
            </div>
            <a
              href={YOUTUBE_CHANNEL_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary justify-center text-xs shrink-0"
            >
              {t.videos.viewChannel}
            </a>
          </div>
        </div>
      )}

      {rest.length > 0 && (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
          {rest.map(video => (
            <article class="glass-panel overflow-hidden border border-white/10 hover:border-signal-cyan/30 transition-colors group">
              <a
                href={video.watchUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="block relative"
                title={video.displayTitle}
              >
                <img
                  src={video.thumbnail}
                  alt={`${video.displayTitle} — ${t.videos.thumbAlt}`}
                  loading="lazy"
                  decoding="async"
                  width="480"
                  height="360"
                  class="w-full aspect-video object-cover bg-black/40 group-hover:opacity-90 transition-opacity"
                />
                <span class="absolute inset-0 flex items-center justify-center">
                  <span class="w-12 h-12 rounded-full bg-red-600/90 flex items-center justify-center shadow-lg group-hover:scale-105 transition-transform">
                    <svg class="w-5 h-5 text-white ms-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                </span>
              </a>
              <div class="p-3 sm:p-4">
                <h3 class="text-sm font-semibold text-white/90 line-clamp-2">{video.displayTitle}</h3>
                <p class="text-xs text-white/40 mt-1">{formatDate(video.published)}</p>
              </div>
            </article>
          ))}
        </div>
      )}

      <div class="mt-8 text-center">
        <a
          href={YOUTUBE_CHANNEL_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-white/50 hover:text-red-400 transition-colors"
        >
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.8 15.5v-7l6.3 3.5-6.3 3.5z" />
          </svg>
          {t.videos.viewChannel}
        </a>
      </div>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': videoSchema.map(video => ({
        ...video,
        '@context': 'https://schema.org',
      })),
    })} />
  </section>
)}
