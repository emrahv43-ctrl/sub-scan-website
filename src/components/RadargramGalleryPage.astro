const imageItems = galleryImages.map(item => ({
  file: item.file,
  title: item.title[lang],
  alt: item.alt[lang],
  src: `/gallery/processed/${item.file}`,
}));

const alternates = [
  { lang: 'tr', href: `${SITE_URL}/gpr-radargram-ornekleri` },
  { lang: 'en', href: `${SITE_URL}/en/gpr-radargram-gallery` },
  { lang: 'ar', href: `${SITE_URL}/ar/gpr-radargram-gallery` },
  { lang: 'x-default', href: `${SITE_URL}/gpr-radargram-ornekleri` },
];

const imageGallerySchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: page.heading,
  description: page.description,
  inLanguage: lang,
  url: SITE_URL + Astro.url.pathname,
  associatedMedia: imageItems.map((item, index) => ({
    '@type': 'ImageObject',
    position: index + 1,
    name: item.title,
    description: item.alt,
    contentUrl: SITE_URL + item.src,
    thumbnailUrl: SITE_URL + item.src,
    encodingFormat: 'image/png',
  })),
};
---

<BaseLayout
  lang={lang}
  dir={t.dir}
  locale={t.locale}
  title={page.title}
  description={page.description}
  keywords={page.keywords}
  hreflangAlternates={alternates}
  structuredData={imageGallerySchema}
>
  <GridBackground />
  <Header t={t} />

  <main class="relative z-10 pt-20 sm:pt-24 pb-16">
    <section class="max-w-6xl mx-auto px-4 sm:px-6">
      <header class="mb-8 sm:mb-10 text-center">
        <span class="text-[10px] font-mono text-signal-cyan tracking-widest">{page.badge}</span>
        <h1 class="text-2xl sm:text-4xl font-bold tracking-tight mt-2 mb-3">{page.heading}</h1>
        <p class="text-white/50 text-sm sm:text-base max-w-2xl mx-auto">{page.subtitle}</p>
      </header>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {imageItems.map((item, index) => (
          <article class="glass-panel overflow-hidden border border-white/10 hover:border-signal-cyan/30 transition-colors">
            <a href={item.src} target="_blank" rel="noopener noreferrer" class="block" title={item.title}>
              <img
                src={item.src}
                alt={item.alt}
                title={item.title}
                width="800"
                height="450"
                loading={index < 6 ? 'eager' : 'lazy'}
                decoding="async"
                class="w-full h-48 sm:h-56 object-cover bg-black/40"
              />
            </a>
            <div class="p-3 sm:p-4">
              <h2 class="text-sm font-semibold text-white/90">{item.title}</h2>
              <p class="text-xs text-white/45 mt-1">{item.alt}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer t={t} />
</BaseLayout>
