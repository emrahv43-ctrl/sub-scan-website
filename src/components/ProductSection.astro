---
interface Props {
  id: string;
  badge: string;
  title: string;
  subtitle: string;
  features: string[];
  screenshot: string;
  screenshotAlt: string;
  reversed?: boolean;
  accentColor?: 'cyan' | 'orange';
  mobile?: boolean;
  dir?: 'ltr' | 'rtl';
}

const {
  id, badge, title, subtitle, features, screenshot, screenshotAlt,
  reversed = false, accentColor = 'cyan', mobile = false, dir = 'ltr',
} = Astro.props;

const isCyan = accentColor === 'cyan';
const badgeClass = isCyan
  ? 'bg-signal-cyan/10 text-signal-cyan border-signal-cyan/20'
  : 'bg-accent-orange/10 text-accent-orange border-accent-orange/20';
const checkClass = isCyan ? 'bg-signal-cyan/10' : 'bg-accent-orange/10';
const iconClass = isCyan ? 'text-signal-cyan' : 'text-accent-orange';

const aspectClass = mobile ? 'aspect-[9/16] max-w-[280px] sm:max-w-xs mx-auto' : 'aspect-[16/10]';
const reverseGrid = reversed && dir === 'ltr' ? 'lg:[direction:rtl]' : reversed && dir === 'rtl' ? 'lg:[direction:ltr]' : '';
const resetDir = reversed ? (dir === 'rtl' ? 'lg:[direction:rtl]' : 'lg:[direction:ltr]') : '';
---

<section id={id} class="relative z-10 py-16 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class={`grid lg:grid-cols-2 gap-8 lg:gap-12 items-center ${reverseGrid}`}>
      <!-- Screenshot -->
      <div class={resetDir}>
        <div class="glass-panel p-1.5 sm:p-2 neon-border">
          <div class={`${aspectClass} rounded-xl bg-ground-work relative overflow-hidden`}>
            <img
              src={screenshot}
              alt={screenshotAlt}
              loading="lazy"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class={resetDir}>
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-mono tracking-wider border mb-3 sm:mb-4 ${badgeClass}`}>
          {badge}
        </span>
        <h2 class="section-title mb-2">{title}</h2>
        <p class="text-white/50 mb-6 sm:mb-8 leading-relaxed text-sm sm:text-base">{subtitle}</p>
        <ul class="space-y-2.5 sm:space-y-3">
          {features.map(f => (
            <li class="flex items-start gap-3 text-sm">
              <span class={`mt-0.5 w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 ${checkClass}`}>
                <svg class={`w-3 h-3 ${iconClass}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              <span class="text-white/70">{f}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
