---
import type { Translations } from '../i18n/types';
import { WHATSAPP, EMAIL } from '../i18n/types';
import BaseLayout from '../layouts/BaseLayout.astro';
import GridBackground from '../components/GridBackground.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RadarAnimation from '../components/RadarAnimation.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ProductSection from '../components/ProductSection.astro';
import WorkflowSection from '../components/WorkflowSection.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const waUrl = `https://wa.me/${WHATSAPP}?text=${encodeURIComponent(t.contact.waMessage)}`;
---

<BaseLayout
  lang={t.lang}
  dir={t.dir}
  locale={t.locale}
  title={t.meta.title}
  description={t.meta.description}
  keywords={t.meta.keywords}
>
  <GridBackground />
  <Header t={t} />

  <main class="relative z-10">
    <!-- Hero -->
    <section class="min-h-[90vh] sm:min-h-screen flex items-center pt-20 sm:pt-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div class="order-2 lg:order-1">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full
                        bg-signal-cyan/10 border border-signal-cyan/20 mb-4 sm:mb-6">
              <span class="w-2 h-2 rounded-full bg-signal-cyan animate-pulse"></span>
              <span class="text-[10px] sm:text-xs font-mono text-signal-cyan tracking-wider">{t.hero.badge}</span>
            </div>

            <h1 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-4 sm:mb-6">
              {t.hero.title1}
              <br />
              <span class="text-gradient neon-text">{t.hero.title2}</span>
              <br />
              {t.hero.title3}
            </h1>

            <p class="text-base sm:text-lg text-white/50 mb-6 sm:mb-8 max-w-lg leading-relaxed">
              {t.hero.description}
            </p>

            <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4">
              <a href="#iletisim" class="btn-primary w-full sm:w-auto justify-center">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                {t.hero.ctaDemo}
              </a>
              <a href="#ozellikler" class="btn-secondary w-full sm:w-auto justify-center">
                {t.hero.ctaExplore}
              </a>
            </div>

            <div class="mt-8 sm:mt-10 flex flex-wrap items-center gap-4 sm:gap-6 text-xs sm:text-sm text-white/30">
              <div class="flex items-center gap-2">
                <span class="text-signal-cyan font-mono font-bold">2</span> {t.hero.statPlatform}
              </div>
              <div class="w-px h-4 bg-white/10 hidden sm:block"></div>
              <div class="flex items-center gap-2">
                <span class="text-signal-cyan font-mono font-bold">2</span> {t.hero.statFormats}
              </div>
              <div class="w-px h-4 bg-white/10 hidden sm:block"></div>
              <div class="flex items-center gap-2">
                <span class="text-signal-cyan font-mono font-bold">50+</span> {t.hero.statFilters}
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2 animate-float max-w-xs sm:max-w-sm lg:max-w-none mx-auto">
            <RadarAnimation />
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="ozellikler" class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10 sm:mb-16">
          <span class="text-xs font-mono text-signal-cyan tracking-widest">{t.features.section}</span>
          <h2 class="section-title mt-2">{t.features.title}</h2>
          <p class="text-white/50 mt-4 max-w-2xl mx-auto text-sm sm:text-base px-2">
            {t.features.subtitle}
          </p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {t.features.items.map(f => (
            <FeatureCard icon={f.icon} title={f.title} description={f.description} />
          ))}
        </div>
      </div>
    </section>

    <!-- Desktop -->
    <ProductSection
      id="masaustu"
      badge={t.desktop.badge}
      title={t.desktop.title}
      subtitle={t.desktop.subtitle}
      features={t.desktop.features}
      screenshot={t.desktop.screenshot}
      screenshotAlt={t.desktop.screenshotAlt}
      accentColor="cyan"
      dir={t.dir}
    />

    <!-- Android -->
    <ProductSection
      id="android"
      badge={t.android.badge}
      title={t.android.title}
      subtitle={t.android.subtitle}
      features={t.android.features}
      screenshot={t.android.screenshot}
      screenshotAlt={t.android.screenshotAlt}
      accentColor="orange"
      reversed={true}
      mobile={true}
      dir={t.dir}
    />

    <!-- Field workflow -->
    <WorkflowSection t={t} />

    <!-- Formats -->
    <section id="formatlar" class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10 sm:mb-16">
          <span class="text-xs font-mono text-signal-cyan tracking-widest">{t.formats.section}</span>
          <h2 class="section-title mt-2">{t.formats.title}</h2>
          <p class="text-white/50 mt-4 text-sm sm:text-base">{t.formats.subtitle}</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
          {t.formats.items.map(f => (
            <div class="glass-panel px-4 sm:px-5 py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 hover:border-signal-cyan/20 transition-colors">
              <span class="font-mono text-sm font-bold text-signal-cyan">{f.ext}</span>
              <span class="text-sm text-white/40">{f.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="iletisim" class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="glass-panel p-6 sm:p-8 md:p-12 text-center neon-border">
          <span class="text-xs font-mono text-signal-cyan tracking-widest">{t.contact.section}</span>
          <h2 class="section-title mt-2 mb-4">{t.contact.title}</h2>
          <p class="text-white/50 max-w-xl mx-auto mb-6 sm:mb-8 text-sm sm:text-base">
            {t.contact.subtitle}
          </p>
          <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-3 sm:gap-4">
            <a href={waUrl} target="_blank" rel="noopener" class="btn-primary w-full sm:w-auto justify-center">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {t.contact.whatsapp}
            </a>
            <a href={`mailto:${EMAIL}`} class="btn-secondary w-full sm:w-auto justify-center">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {t.contact.email}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer t={t} />
  <WhatsAppButton message={t.contact.waMessage} />
</BaseLayout>
