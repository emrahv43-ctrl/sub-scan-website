---
import type { Lang } from '../i18n/types';
import type { SeoPageId } from '../seo/types';
import { getSeoPage, getSeoAlternates } from '../seo';
import { getTranslations } from '../i18n';
import { WHATSAPP, EMAIL } from '../i18n/types';
import BaseLayout from '../layouts/BaseLayout.astro';
import GridBackground from './GridBackground.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';

interface Props {
  pageId: SeoPageId;
  lang: Lang;
}

const { pageId, lang } = Astro.props;
const page = getSeoPage(pageId, lang);
const t = getTranslations(lang);
const homeUrl = t.path;
const waUrl = `https://wa.me/${WHATSAPP}?text=${encodeURIComponent(t.contact.waMessage)}`;

const faqSchema = page.faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: page.faq.map(item => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'SubScan',
      item: `https://sub-scan.com${homeUrl === '/' ? '' : homeUrl}`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: page.hero.title,
    },
  ],
};

const structuredData = faqSchema ? [breadcrumbSchema, faqSchema] : [breadcrumbSchema];
---

<BaseLayout
  lang={lang}
  dir={t.dir}
  locale={t.locale}
  title={page.meta.title}
  description={page.meta.description}
  keywords={page.meta.keywords}
  hreflangAlternates={getSeoAlternates(pageId)}
  structuredData={structuredData}
>
  <GridBackground />
  <Header t={t} />

  <main class="relative z-10 pt-20 sm:pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <!-- Breadcrumb -->
      <nav class="text-xs text-white/40 mb-6" aria-label="Breadcrumb">
        <a href={homeUrl} class="hover:text-signal-cyan transition-colors">SubScan</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">{page.footerLabel}</span>
      </nav>

      <!-- Hero -->
      <header class="mb-10">
        <span class="text-[10px] font-mono text-signal-cyan tracking-widest">{page.hero.badge}</span>
        <h1 class="text-2xl sm:text-4xl font-bold tracking-tight mt-2 mb-4">{page.hero.title}</h1>
        <p class="text-white/50 text-sm sm:text-base leading-relaxed">{page.hero.subtitle}</p>
      </header>

      <!-- Content sections -->
      {page.sections.map(section => (
        <section class="mb-8">
          <h2 class="text-lg sm:text-xl font-semibold text-white/90 mb-3">{section.title}</h2>
          {section.paragraphs.map(p => (
            <p class="text-sm sm:text-base text-white/50 leading-relaxed mb-3">{p}</p>
          ))}
          {section.bullets && (
            <ul class="space-y-2 text-sm text-white/50">
              {section.bullets.map(item => (
                <li class="flex gap-2">
                  <span class="text-signal-cyan flex-shrink-0">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}
        </section>
      ))}

      <!-- FAQ -->
      {page.faq && (
        <section class="mb-10">
          <div class="glass-panel border border-white/10 rounded-xl divide-y divide-white/10">
            {page.faq.map(item => (
              <details class="group p-4 sm:p-5">
                <summary class="font-medium text-sm sm:text-base text-white/90 cursor-pointer list-none flex justify-between gap-3">
                  {item.question}
                  <span class="text-signal-cyan/60 group-open:rotate-45 transition-transform text-lg leading-none">+</span>
                </summary>
                <p class="text-sm text-white/50 mt-3 leading-relaxed">{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      <section class="glass-panel p-6 sm:p-8 text-center neon-border mt-10">
        <h2 class="text-lg sm:text-xl font-bold mb-2">{page.cta.title}</h2>
        <p class="text-sm text-white/50 mb-5">{page.cta.subtitle}</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href={waUrl} target="_blank" rel="noopener" class="btn-primary justify-center">
            {t.contact.whatsapp}
          </a>
          <a href={`mailto:${EMAIL}`} class="btn-secondary justify-center">
            {t.contact.email}
          </a>
          <a href={`${homeUrl}#masaustu`} class="btn-secondary justify-center">
            {t.nav.desktop}
          </a>
        </div>
      </section>

      <!-- Back to home -->
      <p class="text-center mt-8">
        <a href={homeUrl} class="text-sm text-white/40 hover:text-signal-cyan transition-colors">
          {t.footer.backHome}
        </a>
      </p>
    </div>
  </main>

  <Footer t={t} />
</BaseLayout>
