---
import type { Translations } from '../i18n/types';
import { EMAIL, WHATSAPP, PHONE_DISPLAY, YOUTUBE_CHANNEL_URL } from '../i18n/types';
import { getSeoFooterLinks } from '../seo';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const year = new Date().getFullYear();
const waUrl = `https://wa.me/${WHATSAPP}`;
const home = t.path;
const guideLinks = getSeoFooterLinks(t.lang);
---

<footer class="relative z-10 border-t border-white/5 bg-ground-panel/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-signal-cyan to-signal-green
                      flex items-center justify-center font-bold text-black text-xs">SS</div>
          <span class="font-bold">SubScan</span>
        </div>
        <p class="text-sm text-white/50 leading-relaxed">{t.footer.description}</p>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4 text-white/80">{t.footer.products}</h4>
        <ul class="space-y-2 text-sm text-white/50">
          <li><a href={`${home}#masaustu`} class="hover:text-signal-cyan transition-colors">SubScan Desktop</a></li>
          <li><a href={`${home}#android`} class="hover:text-signal-cyan transition-colors">SubScan Android</a></li>
          <li><a href={`${home}#ekipman`} class="hover:text-signal-cyan transition-colors">{t.nav.partners}</a></li>
          <li><a href={`${home}#saha`} class="hover:text-signal-cyan transition-colors">{t.nav.workflow}</a></li>
          <li><a href={`${home}#formatlar`} class="hover:text-signal-cyan transition-colors">{t.nav.formats}</a></li>
          <li><a href={`${home}#videolar`} class="hover:text-signal-cyan transition-colors">{t.nav.videos}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4 text-white/80">{t.footer.guides}</h4>
        <ul class="space-y-2 text-sm text-white/50">
          {guideLinks.map(link => (
            <li>
              <a href={link.href} class="hover:text-signal-cyan transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4 text-white/80">{t.footer.contact}</h4>
        <ul class="space-y-2 text-sm text-white/50">
          <li>
            <a href={`mailto:${EMAIL}`} class="hover:text-signal-cyan transition-colors">{EMAIL}</a>
          </li>
          <li>
            <a href={waUrl} target="_blank" rel="noopener" class="hover:text-signal-cyan transition-colors">
              {PHONE_DISPLAY}
            </a>
          </li>
          <li>
            <a href={YOUTUBE_CHANNEL_URL} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-red-400 transition-colors">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.8 15.5v-7l6.3 3.5-6.3 3.5z"/></svg>
              YouTube
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 sm:mt-10 pt-6 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-white/30">&copy; {year} SubScan. {t.footer.rights}</p>
      <p class="text-xs text-white/30 font-mono">sub-scan.com</p>
    </div>
  </div>
</footer>
